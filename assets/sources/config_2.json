{
  "search_config": {
    "url": "{host}/index.php/vod/search.html?wd={q}",
    "cookie": "ds_notice=1; PHPSESSID=e70h75bjokmgcd2j5hp7i7ma3k",
    "details_format": "{host}{result}",
    "item_regex": "<div class=\"[^\"]*search-list[^\"]*\">[\\s\\S]*?data-src=\"([^\"]+)\"[\\s\\S]*?<a[^>]*href=\"([^\"]+)\"[^>]*>[\\s\\S]*?<h3[^>]*>([\\s\\S]*?)<\\/h3>",
    "fields": {
      "image": {
        "match_index": 1,
        "description": "作品封面图片地址"
      },
      "url": {
        "match_index": 2,
        "description": "详情页跳转链接"
      },
      "title": {
        "match_index": 3,
        "description": "作品标题名称"
      }
    }
  }
}